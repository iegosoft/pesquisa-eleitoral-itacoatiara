rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function autenticado() {
      return request.auth != null;
    }

    function role() {
      return autenticado()
        ? get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role
        : null;
    }

    function ehAdmin() {
      return role() == 'admin';
    }

    function ehPesquisador() {
      return role() == 'pesquisador';
    }

    match /usuarios/{uid} {
      allow read: if autenticado() && (request.auth.uid == uid || ehAdmin());
      allow write: if ehAdmin();
    }

    match /candidatos/{candidatoId} {
      allow read: if autenticado();
      allow write: if ehAdmin();
    }

    // Configurações administráveis só pelo admin, mas visíveis pros dois
    // papéis (ex.: configuracoes/bairros, com a lista fixa de bairros que
    // o pesquisador usa no formulário de coleta).
    match /configuracoes/{documentoId} {
      allow read: if autenticado();
      allow write: if ehAdmin();
    }

    match /residencias/{residenciaId} {
      function ehDonoDaResidencia() {
        return autenticado() && resource.data.pesquisador_id == request.auth.uid;
      }

      // Admin também cria residências direto (inserção em lote via CSV de
      // dados coletados em papel), além do próprio pesquisador em campo.
      allow create: if ehAdmin() || (ehPesquisador() && request.resource.data.pesquisador_id == request.auth.uid);
      allow read, update: if ehAdmin() || ehDonoDaResidencia();
      allow delete: if ehAdmin();

      match /entrevistados/{entrevistadoId} {
        // A criação não checa se a residência é do pesquisador: residência e
        // entrevistados são gravados no mesmo lote atômico, e um get() aqui
        // não enxergaria a residência sendo criada nesse mesmo lote (o
        // Firestore avalia regras contra o estado já confirmado no banco,
        // não contra outras escritas pendentes do mesmo lote). Exigir essa
        // checagem faria o lote inteiro ser recusado.
        allow create: if ehAdmin() || ehPesquisador();

        // Leitura e edição só pelo admin: nenhuma tela do pesquisador lê
        // entrevistados hoje (só cria), e um get() com o residenciaId do
        // caminho aqui quebra consultas collectionGroup (usadas pelo
        // dashboard e pela exportação de CSV) mesmo pro admin.
        allow read, update: if ehAdmin();
        allow delete: if ehAdmin();
      }
    }

    // Regra à parte pra consultas collectionGroup em "entrevistados" (usadas
    // pelo dashboard e pela exportação de CSV, que buscam moradores de TODAS
    // as residências de uma vez). O Firestore só reconhece regra de leitura
    // pra esse tipo de consulta quando ela é declarada com o curinga
    // recursivo no topo — a regra aninhada dentro de /residencias funciona
    // pra criar/ler um entrevistado específico, mas não é suficiente pra
    // esse tipo de busca ampla.
    match /{caminho=**}/entrevistados/{entrevistadoId} {
      allow read: if ehAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
